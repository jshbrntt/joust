{
  "name": "${localWorkspaceFolderBasename}",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "${localWorkspaceFolderBasename}",
  "runArgs": [
    "--gpus=all",
    "--shm-size=2g"
  ],
  "containerEnv": {
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "all"
  },
  "features": {
    "./features/alpine-project": {
      "project": "${localWorkspaceFolderBasename}",
      "packages": "openssh sudo tig"
    },
    "./features/codex": {},
    "./features/persist-files": {
      "user": "${localWorkspaceFolderBasename}",
      "group": "${localWorkspaceFolderBasename}",
      "paths": "file:/home/$USER/.bash_history,directory:/home/$USER/.codex,directory:/home/$USER/.ssh"
    },
    "./features/playwright-mcp": {}
  },
  "overrideFeatureInstallOrder": [
    "./features/alpine-project",
    "./features/codex",
    "./features/persist-files",
    "./features/playwright-mcp"
  ],
  "customizations": {
    "extensions": {
      "vscode": [
        "eamodio.gitlens",
        "oven.bun-vscode"
      ]
    }
  }
}
