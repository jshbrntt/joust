{
  "id": "docker-in-docker",
  "version": "1.0.0",
  "name": "Docker-in-Docker (Alpine)",
  "description": "Minimal Docker-in-Docker for Alpine-based images.",
  "entrypoint": "/usr/local/share/docker-init.sh",
  "privileged": true,
  "containerEnv": {
    "DOCKER_BUILDKIT": "1"
  },
  "mounts": [
    {
      "source": "dind-var-lib-docker-${devcontainerId}",
      "target": "/var/lib/docker",
      "type": "volume"
    }
  ]
}
