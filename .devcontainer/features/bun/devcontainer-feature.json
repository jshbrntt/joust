{
    "id": "bun",
    "version": "1.0.0",
    "name": "Bun",
    "description": "Installs Bun for Alpine/musl containers.",
    "options": {
        "version": {
            "type": "string",
            "default": "1.3.12",
            "description": "Bun version to install."
        },
        "user": {
            "type": "string",
            "default": "vscode",
            "description": "User whose shell startup should include ~/.bun/bin."
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "oven.bun-vscode"
            ]
        }
    }
}
